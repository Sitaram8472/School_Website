# Server
PORT=5000

# MongoDB
MONGO_URL=mongodb://127.0.0.1:27017/school_website

# JWT
JWT_SECRET=your_jwt_secret_key_here

# Optional: Email (for password reset in production)
# If not set, reset links are logged to the console (development mode)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Optional: Frontend URL (used in reset email link)
FRONTEND_URL=http://localhost:5173

# =============================================
# Rate Limiting Configuration
# =============================================
# Login: 5 attempts per 15 minutes
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=15

# Register: 3 attempts per 1 hour
RATE_LIMIT_REGISTER_MAX=3
RATE_LIMIT_REGISTER_WINDOW=60

# Forgot Password: 3 attempts per 1 hour
RATE_LIMIT_FORGOT_PASSWORD_MAX=3
RATE_LIMIT_FORGOT_PASSWORD_WINDOW=60

# Resend Verification: 3 attempts per 1 hour
RATE_LIMIT_RESEND_VERIFICATION_MAX=3
RATE_LIMIT_RESEND_VERIFICATION_WINDOW=60

# Refresh Token: 10 attempts per 15 minutes
RATE_LIMIT_REFRESH_TOKEN_MAX=10
RATE_LIMIT_REFRESH_TOKEN_WINDOW=15